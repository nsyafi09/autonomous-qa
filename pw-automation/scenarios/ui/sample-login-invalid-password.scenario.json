{
  "id": "login-invalid-password",
  "name": "Invalid password shows error",
  "description": "Verifies that an invalid password shows the correct error message. Uses same targets as the valid login scenario — different data, different outcome.",
  "tags": ["login", "negative"],
  "steps": [
    { "action": "open", "target": "/login" },
    { "action": "input", "target": "login.username", "valueRef": "users.valid.username" },
    { "action": "input", "target": "login.password", "valueRef": "users.invalid.password" },
    { "action": "click", "target": "login.submitButton" },
    { "action": "verifyText", "target": "login.flashMessage", "expected": "Your password is invalid!" }
  ]
}
