{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "web-scenario.schema.json",
  "title": "WebScenario",
  "description": "An approved scenario JSON file — executed by WebScenarioRunner.ts in pw-automation.",
  "type": "object",
  "required": ["id", "name", "steps"],
  "properties": {
    "id":          { "type": "string", "pattern": "^[a-z0-9-]+$", "description": "Kebab-case unique identifier" },
    "name":        { "type": "string" },
    "description": { "type": "string" },
    "tags":        { "type": "array", "items": { "type": "string" } },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action", "target"],
        "properties": {
          "action":      { "type": "string", "enum": ["open", "click", "doubleClick", "input", "clear", "pressKey", "select", "hover", "check", "uncheck", "verifyVisible", "verifyHidden", "verifyText", "verifyExactText", "verifyValue", "verifyChecked", "verifyUnchecked", "verifyUrl"] },
          "target":      { "type": "string" },
          "value":       { "type": "string" },
          "valueRef":    { "type": "string" },
          "expected":    { "type": "string" },
          "expectedRef": { "type": "string" },
          "key":         { "type": "string", "description": "pressKey action only" }
        }
      }
    }
  }
}
