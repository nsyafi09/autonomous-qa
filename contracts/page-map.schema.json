{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "page-map.schema.json",
  "title": "PageMap",
  "description": "Output of PageMapper.ts — describes a scanned page's elements, locators, and detected features.",
  "type": "object",
  "required": ["schemaVersion", "url", "path", "pageName", "scannedAt", "detectedFeatures", "targets"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "url":           { "type": "string", "format": "uri" },
    "path":          { "type": "string" },
    "title":         { "type": "string" },
    "pageName":      { "type": "string" },
    "scannedAt":     { "type": "string" },
    "ariaSnapshot":  { "type": "string" },
    "detectedFeatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature", "confidence"],
        "properties": {
          "feature":    { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence":   { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "locatorCandidates"],
        "properties": {
          "type":      { "type": "string", "enum": ["input", "password", "textarea", "select", "checkbox", "radio", "button", "heading", "link"] },
          "humanName": { "type": "string" },
          "label":     { "type": "string" },
          "text":      { "type": "string" },
          "role":      { "type": "string" },
          "tag":       { "type": "string" },
          "placeholder": { "type": "string" },
          "locatorCandidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["strategy", "score"],
              "properties": {
                "strategy":   { "type": "string", "enum": ["label", "role", "placeholder", "text", "css", "cssNth"] },
                "value":      { "type": "string" },
                "role":       { "type": "string" },
                "name":       { "type": "string" },
                "exact":      { "type": "boolean" },
                "index":      { "type": "integer", "minimum": 0 },
                "score":      { "type": "number" },
                "matchCount": { "type": "integer" },
                "isUnique":   { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
